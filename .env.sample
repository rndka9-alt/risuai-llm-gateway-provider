# probe 스크립트용 환경변수 샘플.
#
# 사용법:
#   cp .env.sample .env   # 값 채우기 (.env는 gitignore 대상)
#   node --env-file=.env scripts/probe-cache-contract.mjs
#   node --env-file=.env scripts/probe-cache-cost.mjs
#
# ⚠️ probe는 실행 즉시 실제 API 비용이 청구됩니다. 각 스크립트 상단의 비용 고지를
# 확인한 뒤 실행하세요.

# API 키 (probe 출력에서는 자동 redact)
PROBE_API_KEY=

# 선택 오버라이드 (기본값은 각 스크립트 상단 상수 참고)
#PROBE_MODEL=gpt-5.6-sol
#PROBE_BASE_URL=https://api.llmgateway.io/v1
#PROBE_SERVICE_TIER=default
